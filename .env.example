# ── Server ──────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ────────────────────────────────
# SQLite (local development)
DB_PATH=./ghost.sqlite
# PostgreSQL (production - Render, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_ENCRYPTION_KEY=your-strong-passphrase    # Enables SQLCipher encryption (requires @journeyapps/sqlcipher)

# ── Security ────────────────────────────────
# HMAC master secret for WebSocket message authentication (auto-generated if not set)
# Generate with: openssl rand -hex 32
# HMAC_MASTER_SECRET=your-64-char-hex-secret-here

# ── IPFS (Pinata) ──────────────────────────
# JWT token for Pinata IPFS uploads (file attachments, avatars, voice messages)
# Get one at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your-pinata-jwt-token

# ── Aleo ────────────────────────────────────
ALEO_API_URL=https://api.explorer.provable.com/v1
ALEO_PROGRAM_ID=ghost_msg_018.aleo
ALEO_NETWORK=testnet

# ── Web Push (optional) ────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
