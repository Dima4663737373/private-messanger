# Render Environment Variables Template
# Copy these to Render dashboard → Environment tab

# Server
PORT=3002

# Database — PostgreSQL (REQUIRED for production / Render)
# Render auto-sets this when you add a PostgreSQL addon
# Local dev: leave empty to use SQLite
DATABASE_URL=postgresql://user:password@host:5432/ghost_db

# CORS - add your frontend URL after deployment
CORS_ORIGINS=http://localhost:3000,https://your-frontend.netlify.app

# Aleo Network (optional - for indexer service)
ALEO_ENDPOINT=https://api.explorer.provable.com/v1
ALEO_NETWORK=testnet
ALEO_PROGRAM_ID=ghost_msg_018.aleo

# IPFS (Pinata) — required for file attachments, avatars
# Get JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your-pinata-jwt-token

# Web Push (optional — enables push notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
